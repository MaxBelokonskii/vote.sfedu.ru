# === Required ===

SECRET_KEY_BASE=generate-with-bin-rails-secret
APPLICATION_HOST=vote.sfedu.ru

# --- Database (production uses DATABASE_URL, built from these in docker-compose) ---
POSTGRES_USER=vote
POSTGRES_PASSWORD=vote
POSTGRES_DB=vote_production

# --- S3 / MinIO ---
S3_BUCKET=vote-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
# S3_ENDPOINT=http://minio:9000  # set automatically in docker-compose; override for external S3

# --- Azure AD OAuth ---
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# --- SOAP / 1C API ---
SFEDU_WSDL_PATH=
SFEDU_WSDL_USERNAME=
SFEDU_WSDL_PASSWORD=

# --- Microsoft Graph (OAuth2 email delivery) ---
# В Azure AD создайте отдельное application registration с application-permission
# Mail.Send, предоставьте admin consent и заполните значения ниже.
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SENDER_EMAIL=noreply@sfedu.ru

# === Optional ===

# DEVISE_MAILER_SENDER=noreply@sfedu.ru
# ASSET_HOST=vote.sfedu.ru
# RAILS_SERVE_STATIC_FILES=true
# SOAP_OPEN_TIMEOUT=10
# SOAP_READ_TIMEOUT=30
# WEB_CONCURRENCY=2
# MAX_THREADS=2
# DB_POOL=5
# JOB_CONCURRENCY=1
# DEBUG_LOGIN_INTO_ACCOUNT=true  # only for dev/test!
# OPS_MAINTENANCE_WARNING=true   # show maintenance banner on homepage
# AZURE_LOGIN_ENABLED=true       # use Azure AD login instead of OpenID
