<%- if Flipper.enabled?(:azure_login) %>
  <div class="bg-white rounded-2xl shadow-xl p-8 max-w-md w-full border border-amber-200">
    <h3 class="text-xl font-semibold text-gray-900 mb-6">Вход в личный кабинет</h3>

    <%= form_tag user_azure_oauth2_omniauth_authorize_path, method: :post do %>
      <button class="w-full px-6 py-3 bg-primary text-white rounded-xl hover_bg-primary-700 transition-colors duration-200 font-medium cursor-pointer border-0" type="submit">Войти через Microsoft</button>
    <%- end %>
  </div>
<%- else %>
  <auth-form path="/sign_in" name="user[identity_url]">
    <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
  </auth-form>
<%- end %>
